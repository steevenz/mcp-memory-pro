  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.11",
    "pino-pretty": "^11.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "src",
    "bin",
    "package.json"
  ]
