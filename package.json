{
  "name": "@modelcontextprotocol/memory-pro",
  "version": "2.0.0",
  "description": "MCP Server with SQLite-backed knowledge graph memory",
  "license": "MIT",
  "main": "src/index.ts",
  "bin": {
    "memory-pro": "bin/memory-pro.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
